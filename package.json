{
  "name": "kiri-factory",
  "version": "0.1.0",
  "description": "Inferred, schema-driven Drizzle factories for real database tests and complex relation graphs",
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "factory",
    "inference",
    "pglite",
    "schema-driven",
    "testing"
  ],
  "homepage": "https://github.com/nxsdev/kiri-factory",
  "bugs": {
    "url": "https://github.com/nxsdev/kiri-factory/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxsdev/kiri-factory.git"
  },
  "files": [
    "dist",
    "packages/rqb-v1/dist",
    "packages/rqb-v2/dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./rqb-v1": {
      "types": "./packages/rqb-v1/dist/index.d.mts",
      "import": "./packages/rqb-v1/dist/index.mjs"
    },
    "./rqb-v2": {
      "types": "./packages/rqb-v2/dist/index.d.mts",
      "import": "./packages/rqb-v2/dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp run build:workspace",
    "build:pkg": "vp pack",
    "build:rqb-v1": "vp run @kiri-factory/rqb-v1-internal#build",
    "build:rqb-v2": "vp run @kiri-factory/rqb-v2-internal#build",
    "check": "vp run check:workspace",
    "check:pkg": "vp check",
    "check:rqb-v1": "vp run @kiri-factory/rqb-v1-internal#check",
    "check:rqb-v2": "vp run @kiri-factory/rqb-v2-internal#check",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build",
    "test": "vp run test:workspace",
    "test:rqb-v1": "vp run @kiri-factory/rqb-v1-internal#test",
    "test:rqb-v2": "vp run @kiri-factory/rqb-v2-internal#test",
    "test:watch": "vp run @kiri-factory/rqb-v1-internal#test:watch"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:",
    "drizzle-orm": "catalog:rqb-v1",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.45.2 <0.46.0 || >=1.0.0-beta.1 <2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.4.1"
}
